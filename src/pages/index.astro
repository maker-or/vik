---
import Layout from '../layouts/Layout.astro';

const categoryImages = {
	coffee: [
		'/img-1.png',
		'/img-2.png',
		'/img-3.png',
		'/img-4.png',
		'/img-5.png',
		'/img-6.png',
	],
	pizza: ['/pizza-1.png', '/pizza-2.png', '/pizza-3.png', '/pizza-4.png'],
	burgers: ['/burger-1.png', '/burger-2.png', '/burger-3.png', '/burger-4.png'],
};

const menu = {
	coffee: [
	{
		number: '01',
		name: 'Espresso',
		description:
			'A short, dark pour with cocoa depth, toasted sugar, and a clean finish that lingers.',
	},
	{
		number: '02',
		name: 'Latte',
		description:
			'Velvet milk folded into house espresso for a rounded cup with caramel softness.',
	},
	{
		number: '03',
		name: 'Mocha',
		description:
			'Dark chocolate, espresso, and steamed milk layered into a rich afternoon comfort.',
	},
	{
		number: '04',
		name: 'Cold Brew',
		description:
			'Slow-steeped overnight for a bold, smooth glass with low bitterness and bright lift.',
	},
	{
		number: '05',
		name: 'Flat White',
		description:
			'A tighter milk pour and strong espresso core for a silky cup with real structure.',
	},
	{
		number: '06',
		name: 'Matcha Tonic',
		description:
			'Ceremonial matcha lifted with citrus tonic for a chilled, green, sparkling finish.',
	},
	],
	pizza: [
		{
			number: '01',
			name: 'Margherita',
			description:
				'Stone-baked with bright tomato, torn basil, and soft mozzarella across a thin crust.',
		},
		{
			number: '02',
			name: 'Mushroom',
			description:
				'Roasted mushrooms, brown butter onion, and creamy cheese with an earthy finish.',
		},
		{
			number: '03',
			name: 'Pepperoni',
			description:
				'Crisp-edged pepperoni with slow tomato sauce and a balanced chili warmth.',
		},
		{
			number: '04',
			name: 'Pesto Garden',
			description:
				'Herb pesto, zucchini ribbons, olives, and mozzarella on a blistered base.',
		},
		{
			number: '05',
			name: 'Four Cheese',
			description:
				'A rich white pizza layered with mozzarella, parmesan, provolone, and gorgonzola.',
		},
		{
			number: '06',
			name: 'Smoked Corn',
			description:
				'Charred sweet corn, smoked paprika cream, and fresh herbs on a golden crust.',
		},
	],
	burgers: [
		{
			number: '01',
			name: 'Classic Melt',
			description:
				'Seared patty, cheddar, onion, and mustard mayo tucked into a soft toasted bun.',
		},
		{
			number: '02',
			name: 'Crispy Chicken',
			description:
				'Buttermilk fried chicken with lettuce, pickles, and pepper sauce for a sharp bite.',
		},
		{
			number: '03',
			name: 'Double Smash',
			description:
				'Two crisp beef patties, American cheese, and grilled onions with extra edge.',
		},
		{
			number: '04',
			name: 'Veg Stack',
			description:
				'A layered vegetable patty with slaw, tomato, and herb dressing in a warm bun.',
		},
		{
			number: '05',
			name: 'BBQ Bacon',
			description:
				'Sticky barbecue glaze, smoked bacon, and cheddar with a dark roasted finish.',
		},
		{
			number: '06',
			name: 'Green Chili',
			description:
				'Beef, green chili relish, and jack cheese with a bright, savory heat.',
		},
	],
};

---

<Layout>
	<main class="overflow-hidden">
		<section class="mx-auto max-w-7xl px-5 py-8 sm:px-8 lg:px-12 lg:py-12">
			<div class="mb-8 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 sm:mb-10 sm:gap-x-4">
				<button
					type="button"
					class="menu-tab font-['Fraunces'] text-5xl leading-none text-[var(--brown-700,#7b341b)] transition-opacity hover:opacity-100 sm:text-6xl lg:text-7xl"
					data-category-tab="coffee"
					aria-pressed="true"
				>
					coffee
				</button>
				<span class="font-['Fraunces'] text-5xl leading-none text-[var(--brown-700,#7b341b)] sm:text-6xl lg:text-7xl">.</span>
				<button
					type="button"
					class="menu-tab font-['Fraunces'] text-5xl leading-none text-[var(--brown-700,#7b341b)] opacity-45 transition-opacity hover:opacity-100 sm:text-6xl lg:text-7xl"
					data-category-tab="pizza"
					aria-pressed="false"
				>
					pizza
				</button>
				<span class="font-['Fraunces'] text-5xl leading-none text-[var(--brown-700,#7b341b)] sm:text-6xl lg:text-7xl">.</span>
				<button
					type="button"
					class="menu-tab font-['Fraunces'] text-5xl leading-none text-[var(--brown-700,#7b341b)] opacity-45 transition-opacity hover:opacity-100 sm:text-6xl lg:text-7xl"
					data-category-tab="burgers"
					aria-pressed="false"
				>
					burgers
				</button>
			</div>
			{
				Object.entries(menu).map(([category, items]) => (
					<div
						class:list={[
							'menu-panel grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 lg:gap-7',
							category === 'coffee' ? '' : 'hidden',
						]}
						data-category-panel={category}
					>
				{
					items.map((drink, index) => {
						const imageSet = categoryImages[category];
						const imageSrc = imageSet[index % imageSet.length];

						return (
							<article class="mx-auto w-full max-w-[26rem] bg-white p-3 shadow-[0_18px_40px_rgba(86,46,27,0.08)]">
								<div class="flex min-h-[24rem] items-center justify-center bg-[#fbf8f4] px-6 py-8 sm:min-h-[26rem]">
									<img
										src={imageSrc}
										alt={drink.name}
										class:list={[
											'block w-auto object-contain',
											index === 3
												? 'max-h-[12rem] max-w-[72%] sm:max-h-[14rem]'
												: 'max-h-[15rem] max-w-[82%] sm:max-h-[18rem]',
										]}
									/>
								</div>
								<div class="flex items-end justify-between gap-4 border-t border-[rgba(47,18,6,0.08)] px-1 pb-1 pt-4">
									<div class="min-w-0">
										<h3 class="font-['Fraunces'] text-[1.85rem] leading-none text-black sm:text-[2rem]">
											{drink.name}
										</h3>
										<p class="mt-2 max-w-[14rem] font-['Cormorant_Garamond'] text-lg leading-tight text-[rgba(0,0,0,0.82)] sm:text-xl">
											{drink.description}
										</p>
									</div>
									<span class="shrink-0 font-['Fraunces'] text-5xl leading-none text-black sm:text-6xl">
										{drink.number}
									</span>
								</div>
							</article>
						);
					})
				}
					</div>
				))
			}
		</section>
	</main>
</Layout>

<script is:inline>
	const tabs = Array.from(document.querySelectorAll('[data-category-tab]'));
	const panels = Array.from(document.querySelectorAll('[data-category-panel]'));

	const setActiveCategory = (category) => {
		tabs.forEach((tab) => {
			const active = tab.dataset.categoryTab === category;
			tab.setAttribute('aria-pressed', active ? 'true' : 'false');
			tab.classList.toggle('opacity-45', !active);
		});

		panels.forEach((panel) => {
			const active = panel.dataset.categoryPanel === category;
			panel.classList.toggle('hidden', !active);
		});
	};

	tabs.forEach((tab) => {
		tab.addEventListener('click', () => {
			setActiveCategory(tab.dataset.categoryTab);
		});
	});
</script>
