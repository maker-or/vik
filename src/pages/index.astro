---
import Layout from '../layouts/Layout.astro';

const gallery = [
	'/img-1.png',
	'/img-2.png',
	'/img-3.png',
	'/img-4.png',
	'/img-5.png',
	'/img-6.png',
];

const drinks = [
	{
		number: '01',
		name: 'Espresso',
		description:
			'A short, dark pour with cocoa depth, toasted sugar, and a clean finish that lingers.',
	},
	{
		number: '02',
		name: 'Latte',
		description:
			'Velvet milk folded into house espresso for a rounded cup with caramel softness.',
	},
	{
		number: '03',
		name: 'Mocha',
		description:
			'Dark chocolate, espresso, and steamed milk layered into a rich afternoon comfort.',
	},
	{
		number: '04',
		name: 'Cold Brew',
		description:
			'Slow-steeped overnight for a bold, smooth glass with low bitterness and bright lift.',
	},
	{
		number: '05',
		name: 'Flat White',
		description:
			'A tighter milk pour and strong espresso core for a silky cup with real structure.',
	},
	{
		number: '06',
		name: 'Matcha Tonic',
		description:
			'Ceremonial matcha lifted with citrus tonic for a chilled, green, sparkling finish.',
	},
];
---

<Layout>
	<main class="overflow-hidden">
		<section class="mx-auto max-w-7xl px-5 py-8 sm:px-8 lg:px-12 lg:py-12">
			<h1 class="mb-8 text-center font-['Fraunces'] text-6xl leading-none text-[var(--brown-700,#7b341b)] sm:mb-10 sm:text-7xl lg:text-8xl">
				Vikkys
			</h1>
			<div class="grid grid-cols-1 gap-10 sm:gap-12">
				{
					drinks.map((drink, index) => {
						const alignRight = index % 2 === 1;

						return (
							<article class="relative mx-auto w-full max-w-5xl">
								<div
									class:list={[
										'absolute inset-x-4 bottom-4 z-20 sm:inset-x-6 sm:bottom-6 lg:inset-x-8 lg:bottom-8',
										alignRight ? 'flex justify-end text-right' : 'flex justify-start text-left',
									]}
								>
									<div
										class:list={[
											'grid max-w-3xl items-end gap-3 sm:gap-5',
											alignRight ? 'grid-cols-[1fr_auto]' : 'grid-cols-[auto_1fr]',
										]}
									>
										{alignRight ? (
											<>
												<div>
													<h3 class="font-['Fraunces'] text-3xl leading-none text-black sm:text-4xl lg:text-5xl">
														{drink.name}
													</h3>
													<p class="mt-2 max-w-xl font-['Cormorant_Garamond'] text-lg leading-tight text-black sm:mt-3 sm:text-2xl">
														{drink.description}
													</p>
												</div>
												<span class="font-['Fraunces'] text-5xl leading-none text-black sm:text-6xl lg:text-7xl">
													{drink.number}
												</span>
											</>
										) : (
											<>
												<span class="font-['Fraunces'] text-5xl leading-none text-black sm:text-6xl lg:text-7xl">
													{drink.number}
												</span>
												<div>
													<h3 class="font-['Fraunces'] text-3xl leading-none text-black sm:text-4xl lg:text-5xl">
														{drink.name}
													</h3>
													<p class="mt-2 max-w-xl font-['Cormorant_Garamond'] text-lg leading-tight text-black sm:mt-3 sm:text-2xl">
														{drink.description}
													</p>
												</div>
											</>
										)}
									</div>
								</div>
								<div
									class:list={[
										'relative flex min-h-[28rem] items-center sm:min-h-[34rem] lg:min-h-[42rem]',
										alignRight ? 'justify-end' : 'justify-start',
									]}
								>
									<img
										src={gallery[index]}
										alt={drink.name}
										class="block max-h-[24rem] w-auto max-w-[88%] object-contain sm:max-h-[30rem] sm:max-w-[82%] lg:max-h-[38rem] lg:max-w-[78%]"
									/>
								</div>
							</article>
						);
					})
				}
			</div>
		</section>
	</main>
</Layout>
